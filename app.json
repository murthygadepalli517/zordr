{
  "expo": {
    "name": "Zordr",
    "slug": "zordr",
    "version": "1.0.0",
    "scheme": "zordr",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zordr.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "CADisableMinimumFrameDurationOnPhone": true,
        "NSCameraUsageDescription": "This app needs access to your camera to take profile photos.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to select profile photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.android.zordr",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff"
        }
      ],
      "./plugins/withHighRefreshRate",
      "expo-audio"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c6975066-6ac9-4737-aebb-80490a1ec619"
      }
    }
  }
}
